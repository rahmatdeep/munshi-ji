// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
    url      = env("DATABASE_URL")
}

enum Role {
    ADMIN
    USER
}

model User {
    id            String         @id @default(uuid())
    email         String         @unique
    name          String?
    lawyerId      String
    role          Role           @default(USER)
    createdAt     DateTime       @default(now())
    updatedAt     DateTime       @updatedAt
    magicToken    MagicToken?
    savedCases    Case[]
    personalNotes PersonalNote[]
    sharedNotes   SharedNote[]
    uploadedAttachments CaseAttachment[] @relation("AttachmentUploader")
    deletedAttachments  CaseAttachment[] @relation("AttachmentDeleter")
}

model MagicToken {
    id        String   @id @default(uuid())
    token     String   @unique
    userId    String   @unique
    user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
    expiresAt DateTime
    createdAt DateTime @default(now())
}

// ─── PHHC Case Data ──────────────────────────────────────────────

model Case {
    id              String    @id @default(uuid())
    caseType        String // e.g. "CWP"
    caseNo          String
    caseYear        Int
    cnrNo           String?
    filingNo        String?
    regDate         DateTime?
    petName         String? // Petitioner name
    resName         String? // Respondent name
    petAdvName      String? // Petitioner advocate
    resAdvName      String? // Respondent advocate
    benchName       String?
    status          String? // PENDING, DISPOSED, etc.
    category        String?
    categoryDesc    String?
    district        String?
    establishment   String?
    nextListingDate DateTime?
    disposalDate    DateTime?
    disposalType    String?
    // Raw JSON blob from the API for any extra fields
    rawData         Json?

    parties       CaseParty[]
    hearings      CaseHearing[]
    orders        CaseOrder[]
    objections    CaseObjection[]
    savedBy       User[]
    personalNotes PersonalNote[]
    sharedNotes   SharedNote[]

    lastSyncedAt DateTime?
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    attachments   CaseAttachment[]

    @@unique([caseType, caseNo, caseYear])
}

model CaseParty {
    id      String  @id @default(uuid())
    caseId  String
    case    Case    @relation(fields: [caseId], references: [id], onDelete: Cascade)
    srNo    Int     @default(0)
    type    String // "P" = Petitioner, "R" = Respondent
    name    String
    address String?
    email   String?
    mobile  String?
    age     Int?
    sex     String?

    createdAt DateTime @default(now())
}

model CaseHearing {
    id            String   @id @default(uuid())
    caseId        String
    case          Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
    hearingDate   DateTime
    benchCode     Int?
    benchName     String?
    benchType     String?
    srNo          Int?
    listType      String? // URGENT, SUPPLEMENTARY, etc.
    hearingStatus String?
    courtNo       String?

    createdAt DateTime @default(now())

    @@unique([caseId, hearingDate, srNo])
}

model CaseOrder {
    id        String   @id @default(uuid())
    caseId    String
    case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
    orderDate DateTime
    orderType String? // "I" = Interim, "F" = Final
    benchName String?
    benchCode Int?
    pdfUrl    String?
    pdfName   String?

    createdAt DateTime @default(now())

    @@unique([caseId, orderDate, orderType])
}

model CaseObjection {
    id        String   @id @default(uuid())
    caseId    String
    case      Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
    rawData   Json // Store the entire objection object
    createdAt DateTime @default(now())
}

model PersonalNote {
    id      String @id @default(uuid())
    content String
    userId  String
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    caseId  String
    case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@unique([userId, caseId])
}

model CaseAttachment {
    id              String   @id @default(uuid())
    caseId          String
    case            Case     @relation(fields: [caseId], references: [id], onDelete: Cascade)
    uploaderId      String
    uploader        User     @relation("AttachmentUploader", fields: [uploaderId], references: [id], onDelete: Cascade)
    type            AttachmentType @default(UPLOAD)
    // For uploads
    filename        String?  // Stored filename (on disk)
    originalName    String?  // Original filename from user
    mimetype        String?
    size            Int?
    // For links
    url             String?  // External file link
    // Common metadata
    title           String
    description     String?
    version         Int      @default(1)
    uploadDate      DateTime @default(now())
    deleted         Boolean  @default(false)
    deletedById     String?
    deletedBy       User?    @relation("AttachmentDeleter", fields: [deletedById], references: [id])
    deletedAt       DateTime?

    createdAt       DateTime @default(now())
    updatedAt       DateTime @updatedAt

    @@index([caseId])
    @@index([uploaderId])
    @@index([type])
}

enum AttachmentType {
    UPLOAD
    LINK
}

model SharedNote {
    id      String @id @default(uuid())
    content String
    userId  String
    user    User   @relation(fields: [userId], references: [id], onDelete: Cascade)
    caseId  String
    case    Case   @relation(fields: [caseId], references: [id], onDelete: Cascade)

    createdAt DateTime @default(now())
}
